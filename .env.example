# Copy this file to .env.local and paste your real values after the equals signs.
# NEVER commit your real keys. .env.local is gitignored for you.

# Required. Get a key at https://console.anthropic.com -> Settings -> API Keys
ANTHROPIC_API_KEY=your-key-here

# Optional password gate. If set, visitors must enter this password before they
# can run any research (this protects your API budget). Leave blank/unset to
# keep the app open. Set it in Vercel -> Settings -> Environment Variables too.
APP_PASSWORD=

# Optional. Your real background for the Fit & Angle sections. Server-side only —
# never sent to the browser, never committed. NEVER commit your real value here.
# If unset, a generic example profile is used and the report says so on the page.
# Multiline: wrap the value in double quotes, or use \n escapes. The simplest
# path is to set it only in Vercel (the dashboard accepts multiline values) and
# let local dev run on the example profile.
ABOUT_ME=""
