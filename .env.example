# Copy this file to .env.local and paste your real values after the equals signs.
# NEVER commit your real keys. .env.local is gitignored for you.
#
# If you deploy with the one-click "Deploy to Vercel" button (see the README),
# you'll fill these in on Vercel's web form instead — you won't edit this file.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Your Anthropic API key. Get one at https://console.anthropic.com -> Settings ->
# API Keys. This is read on the server only and never exposed to the browser.
ANTHROPIC_API_KEY=your-key-here

# Password gate. Anyone visiting the site must type this before they can run a
# search (it protects your API budget). REQUIRED once deployed — a live site with
# no password is treated as a misconfiguration and won't run. Pick anything you'll
# remember. (You can leave it blank only when running locally on your computer.)
APP_PASSWORD=

# ---------------------------------------------------------------------------
# Make it your own (personalization)
# ---------------------------------------------------------------------------

# Your first name. The app shows it as "<name>'s Company Profiler" in the header
# and browser tab. Leave blank for a generic "Company Profiler" title.
NEXT_PUBLIC_OWNER_NAME=

# A short summary of your background. Used ONLY to tailor the closing "Fit & Angle"
# section of each profile to you. Include your level/seniority, the kind of role
# you want, your field, what makes a company a good fit, and remote/location
# preference. This is server-only and never sent to the browser.
# (In a .env file, wrap multi-line text in quotes as shown.)
ABOUT_ME="
- Level / seniority: e.g. Senior Marketing Manager, 8+ years.
- Looking for: a full-time marketing leadership role, ideally remote.
- Field: B2B SaaS marketing — demand gen, lifecycle, brand.
- Good-fit company: Series B-D, 200-2000 people, growing, values-driven.
- Location: remote preferred; open to hybrid in the Austin area.
"

# ---------------------------------------------------------------------------
# Optional — a second "advisory / consulting client" angle
# ---------------------------------------------------------------------------

# Off by default (each profile evaluates a company only as a full-time role,
# which is what most job searches want). Set to "true" to ALSO get a second read
# on each company as a potential advisory / consulting client.
NEXT_PUBLIC_ENABLE_ADVISORY_LENS=

# If the advisory lens is on, the name to label it with (e.g. your practice's
# name). Leave blank for a generic "advisory / consulting" label.
NEXT_PUBLIC_ADVISORY_NAME=
